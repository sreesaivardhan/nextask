// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum BoardRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ComplexityStatus {
  PENDING
  ACCEPTED
  OVERRIDDEN
}

enum AIInsightType {
  BOTTLENECK
  SPRINT_RISK
  DIGEST
  TASK_DEADLINE
}

enum AuthProvider {
  LOCAL
  GOOGLE
  GITHUB
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id             String  @id @default(cuid())
  displayName    String
  githubUsername String?

  createdAt DateTime @default(now())

  email         String?      @unique
  passwordHash  String?
  authProvider  AuthProvider @default(LOCAL)
  emailVerified Boolean      @default(false)

  sessions        Session[]
  ownedBoards     Board[]       @relation("BoardOwner")
  boardMembers    BoardMember[]
  assignedCards   Card[]        @relation("CardAssignee")
  lastEditedCards Card[]        @relation("CardLastEditor")
  comments        Comment[]
  activityLogs    ActivityLog[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/// Persists express-session data so sessions survive backend restarts.
model ExpressSession {
  sid       String   @id
  data      String
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model Board {
  id            String    @id @default(cuid())
  name          String
  complexityMax Int?
  sprintEndDate DateTime?
  ownerId       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner        User          @relation("BoardOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members      BoardMember[]
  columns      Column[]
  cards        Card[]
  labels       Label[]
  activityLogs ActivityLog[]
  aiInsights   AIInsight[]

  @@index([ownerId])
}

model BoardMember {
  boardId  String
  userId   String
  role     BoardRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([boardId, userId])
  @@index([userId])
}

model Column {
  id       String @id @default(cuid())
  boardId  String
  name     String
  position Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([boardId])
}

model Card {
  id                 String           @id @default(cuid())
  columnId           String
  boardId            String
  title              String
  description        String?
  assigneeId         String?
  complexity         Int?
  complexityStatus   ComplexityStatus @default(PENDING)
  suggestedSp        Int?
  spConfidence       Int?
  spReasons          Json?
  version            Int              @default(1)
  lastEditedByUserId String?
  githubRepo         String?
  githubIssueNumber  Int?
  position           Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  column       Column      @relation(fields: [columnId], references: [id], onDelete: Cascade)
  board        Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  assignee     User?       @relation("CardAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  lastEditedBy User?       @relation("CardLastEditor", fields: [lastEditedByUserId], references: [id], onDelete: SetNull)
  labels       CardLabel[]
  comments     Comment[]

  @@unique([boardId, githubRepo, githubIssueNumber])
  @@index([columnId, position])
  @@index([boardId])
  @@index([assigneeId])
}

model Label {
  id      String @id @default(cuid())
  boardId String
  name    String
  color   String

  board Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards CardLabel[]

  @@unique([boardId, name])
  @@index([boardId])
}

model CardLabel {
  cardId  String
  labelId String

  card  Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
}

model Comment {
  id     String @id @default(cuid())
  cardId String
  userId String
  body   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([userId])
}

model ActivityLog {
  id         String  @id @default(cuid())
  boardId    String
  userId     String?
  type       String
  entityType String
  entityId   String
  metadata   Json    @default("{}")

  createdAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([boardId])
  @@index([userId])
  @@index([createdAt])
}

model AIInsight {
  id      String        @id @default(cuid())
  boardId String
  type    AIInsightType
  title   String
  summary String
  data    Json          @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId, type])
  @@index([createdAt])
}
