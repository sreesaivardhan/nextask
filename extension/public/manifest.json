{
  "manifest_version": 3,
  "name": "NexTask",
  "version": "1.0.0",
  "description": "Create NexTask cards directly from anywhere on the web.",
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting",
    "cookies"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
